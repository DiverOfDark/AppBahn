{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate-api": "npx openapi-typescript ../api/public-api.yaml -o src/api/schema.ts",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "lint:check": "run-s lint:check:*",
    "lint:check:oxlint": "oxlint .",
    "lint:check:eslint": "eslint . --cache",
    "format": "prettier --write --experimental-cli src/",
    "format:check": "prettier --check --experimental-cli src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "openapi-fetch": "^0.17.0",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.9",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.62.0",
    "eslint-plugin-vue": "~10.9.0",
    "happy-dom": "^20.8.9",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.62.0",
    "prettier": "3.8.3",
    "typescript": "~6.0.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.7"
  },
  "overrides": {
    "glob": "^13.0.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
